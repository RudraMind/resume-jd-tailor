# LLM Provider: gemini | openai | anthropic | groq | ollama | openrouter
LLM_PROVIDER=gemini

# API Keys — only the key for your chosen provider is required
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Optional overrides
LLM_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
PORT=3001
